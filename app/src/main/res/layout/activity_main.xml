<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#0D1117">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🔷 PolyTracker"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#58A6FF"
        android:layout_marginBottom="4dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Copy-trade notifications for Polymarket"
        android:textSize="13sp"
        android:textColor="#8B949E"
        android:layout_marginBottom="24dp"/>

    <!-- Wallet input card -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        app:cardBackgroundColor="#161B22"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp"
        xmlns:app="http://schemas.android.com/apk/res-auto">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TRADER WALLET ADDRESS"
                android:textSize="11sp"
                android:textColor="#8B949E"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp"/>

            <EditText
                android:id="@+id/etWallet"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="0x..."
                android:textColor="#C9D1D9"
                android:textColorHint="#484F58"
                android:background="@null"
                android:textSize="14sp"
                android:fontFamily="monospace"
                android:inputType="text"
                android:singleLine="true"/>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Status + toggle -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="⚪ Not tracking"
        android:textColor="#8B949E"
        android:textSize="13sp"
        android:layout_marginBottom="8dp"/>

    <Button
        android:id="@+id/btnToggle"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Start Tracking"
        android:textColor="#FFFFFF"
        android:backgroundTint="#238636"
        android:layout_marginBottom="24dp"/>

    <!-- Trade feed -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="RECENT TRADES"
        android:textSize="11sp"
        android:textColor="#8B949E"
        android:letterSpacing="0.1"
        android:layout_marginBottom="8dp"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

</LinearLayout>
